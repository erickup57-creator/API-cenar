<section class="admin-shell">
  <div class="admin-panel">
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3 mb-4">
      <div>
        <h1 class="admin-title">Tipos de comercio</h1>
        <p class="admin-subtitle mb-0 mt-2">Categorias visibles para los clientes al buscar comercios.</p>
      </div>
      <a class="admin-submit align-self-start align-self-sm-center" href="/commerceType/save">
        <i class="bi bi-plus-circle me-1"></i>Nuevo tipo
      </a>
    </div>

    {{#if hasCommerceTypes}}
      <div class="admin-grid">
        {{#each commerceTypesList}}
          <article class="admin-item">
            <div class="d-flex gap-3 align-items-start mb-3">
              {{#if this.iconUrl}}
                <img src="{{this.iconUrl}}" alt="{{this.name}}" class="admin-logo flex-shrink-0" />
              {{else}}
                <div class="admin-placeholder d-flex align-items-center justify-content-center flex-shrink-0">
                  {{#if this.iconClass}}
                    <i class="{{this.iconClass}} fs-4"></i>
                  {{else}}
                    <i class="bi bi-tags fs-4"></i>
                  {{/if}}
                </div>
              {{/if}}

              <div style="min-width: 0;">
                <h2 class="h6 fw-bold text-dark mb-1 text-break">{{this.name}}</h2>
                <p class="text-muted small mb-0 text-break">{{this.description}}</p>
              </div>
            </div>

            <div class="admin-divider pt-3">
              <p class="admin-meta mb-3">Comercios asociados: {{this.commercesCount}}</p>

              <div class="d-flex flex-column flex-sm-row gap-2">
                <a href="/commerceType/edit/{{this._id}}" class="btn btn-outline-secondary btn-sm admin-action flex-fill">
                  <i class="bi bi-pencil me-1"></i>Editar
                </a>
                <a href="/commerceType/delete/{{this._id}}" class="btn btn-outline-danger btn-sm admin-action flex-fill">
                  <i class="bi bi-trash3 me-1"></i>Eliminar
                </a>
              </div>
            </div>
          </article>
        {{/each}}
      </div>
    {{else}}
      <div class="admin-empty p-3" role="alert">
        <i class="bi bi-info-circle me-1"></i>No hay tipos de comercio.
      </div>
    {{/if}}
  </div>
</section>
