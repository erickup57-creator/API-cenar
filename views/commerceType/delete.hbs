<section class="admin-shell">
  <div class="admin-panel admin-panel-narrow">
    <div class="mb-4">
      <h1 class="admin-title">Eliminar tipo de comercio</h1>
      <p class="admin-subtitle mb-0 mt-2">Esta accion tambien afectara comercios asociados a este tipo.</p>
    </div>

    <div class="admin-card mb-3">
      <div class="d-flex gap-3 align-items-start">
        <div class="admin-placeholder d-flex align-items-center justify-content-center flex-shrink-0">
          <i class="bi bi-exclamation-triangle fs-4"></i>
        </div>
        <div style="min-width: 0;">
          <h2 class="h6 fw-bold text-dark mb-2 text-break">{{commerceType.name}}</h2>
          <p class="text-muted mb-2">
            Seguro que deseas eliminar este tipo de comercio y todos los comercios asociados?
          </p>
          <p class="admin-meta mb-0">Comercios asociados: {{commercesCount}}</p>
        </div>
      </div>
    </div>

    <div class="d-flex flex-column flex-sm-row gap-2">
      <a href="/commerceType" class="btn btn-outline-secondary admin-back flex-fill">
        <i class="bi bi-arrow-left me-1"></i>Cancelar
      </a>
      <form action="/commerceType/delete/{{commerceType._id}}" method="post" class="flex-fill">
        <button type="submit" class="btn btn-danger admin-danger w-100">
          <i class="bi bi-trash3 me-1"></i>Aceptar
        </button>
      </form>
    </div>
  </div>
</section>
