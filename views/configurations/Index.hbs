<section class="admin-shell">
  <div class="admin-panel">
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3 mb-4">
      <div>
        <h1 class="admin-title">Configuracion</h1>
        <p class="admin-subtitle mb-0 mt-2">Parametros generales de calculo para pedidos.</p>
      </div>
      <a class="admin-submit align-self-start align-self-sm-center" href="/configurations/save">
        <i class="bi bi-plus-circle me-1"></i>Nueva configuracion
      </a>
    </div>

    {{#if hasconfiguration}}
      <div class="admin-grid">
        {{#each configurationList}}
          <article class="admin-item">
            <div class="d-flex gap-3 align-items-center mb-3">
              <div class="admin-icon d-flex align-items-center justify-content-center flex-shrink-0">
                <i class="bi bi-percent fs-4"></i>
              </div>
              <div>
                <h2 class="h6 fw-bold text-dark mb-1">Configuracion fiscal</h2>
                <p class="admin-meta mb-0">ITBIS aplicado: {{this.itbis}}%</p>
              </div>
            </div>

            <a href="/configurations/edit/{{this._id}}" class="btn btn-outline-secondary btn-sm admin-action">
              <i class="bi bi-pencil me-1"></i>Editar
            </a>
          </article>
        {{/each}}
      </div>
    {{else}}
      <div class="admin-empty p-3" role="alert">
        <i class="bi bi-info-circle me-1"></i>No hay configuraciones.
      </div>
    {{/if}}
  </div>
</section>
