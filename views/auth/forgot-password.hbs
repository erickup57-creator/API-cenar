{{#section "styles"}}
<style>
  header {
    display: none;
  }

  main.container {
    max-width: 100%;
    margin-top: 0 !important;
    padding-top: 0;
  }

  body {
    background: #032f3a;
  }

  .auth-shell {
    min-height: 100vh;
    display: grid;
    place-items: center;
  }

  .auth-card {
    width: 100%;
    max-width: 420px;
    background: #ececec;
    border-radius: 10px;
    padding: 22px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.24);
  }

  .auth-title {
    margin: 0 0 18px;
    color: #1f1f1f;
    font-size: 1.85rem;
    font-weight: 700;
    line-height: 1.1;
  }

  .auth-description {
    margin: 0 0 14px;
    color: #4b5358;
    font-size: 0.93rem;
  }

  .auth-input {
    background: #e9ecef;
    border: 1px solid #b9c6ce;
    color: #1e2428;
    padding: 10px 12px;
  }

  .auth-input:focus {
    border-color: #19a8bd;
    box-shadow: 0 0 0 0.18rem rgba(25, 168, 189, 0.25);
    background: #f4f7f9;
  }

  .auth-submit {
    width: 100%;
    border: 0;
    background: #1ca6bd;
    color: #fff;
    font-weight: 600;
    padding: 10px 12px;
    border-radius: 4px;
  }

  .auth-submit:hover {
    background: #168ca0;
  }

  .auth-links {
    margin-top: 12px;
    text-align: center;
    font-size: 0.92rem;
  }
</style>
{{/section}}

<div class="auth-shell">
  <div class="auth-card">
    <h1 class="auth-title">Restablecer contrasena</h1>

    {{#if errors.length}}
    <div class="alert alert-danger py-2 mb-2" role="alert">
      <ul class="mb-0 small">
        {{#each errors}}
        <li>{{this}}</li>
        {{/each}}
      </ul>
    </div>
    {{/if}}

    {{#if success}}
    <div class="alert alert-success py-2 mb-3">Revisa tu correo para continuar.</div>
    {{/if}}

    <p class="auth-description">Ingresa tu usuario o correo para enviarte el enlace de recuperacion.</p>

    <form action="/user/forgot-password" method="POST">
      <div class="mb-3">
        <input
          type="text"
          class="form-control auth-input"
          id="identifier"
          name="identifier"
          value="{{formData.identifier}}"
          placeholder="johndoe@gmail.com"
          required
        />
      </div>

      <button type="submit" class="auth-submit">Enviar enlace</button>
    </form>

    <div class="auth-links">
      <a href="/user/login">Volver a iniciar sesion</a>
    </div>
  </div>
</div>
