{{#section "styles"}}
<style>
  header {
    display: none;
  }

  main.container {
    max-width: 100%;
    margin-top: 0 !important;
    padding-top: 0;
  }

  body {
    background: #032f3a;
  }

  .commerce-shell {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 22px 14px;
  }

  .commerce-card {
    width: 100%;
    max-width: 620px;
    background: #ececec;
    border-radius: 10px;
    padding: 16px;
    font-size: 0.93rem;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.24);
  }

  .commerce-title {
    margin: 0 0 10px;
    color: #1f1f1f;
    font-size: 1.45rem;
    font-weight: 700;
    line-height: 1.1;
  }

  .commerce-subtitle {
    margin: 0 0 10px;
    color: #5e5e5e;
    font-size: 0.88rem;
    font-weight: 600;
  }

  .commerce-label {
    color: #2e2e2e;
    font-size: 0.82rem;
    font-weight: 600;
    margin-bottom: 0.2rem;
  }

  .commerce-input,
  .commerce-select {
    background: #e9ecef;
    border: 1px solid #b9c6ce;
    color: #1e2428;
    padding: 7px 10px;
    font-size: 0.9rem;
  }

  .commerce-input:focus,
  .commerce-select:focus {
    border-color: #19a8bd;
    box-shadow: 0 0 0 0.18rem rgba(25, 168, 189, 0.25);
    background: #f4f7f9;
  }

  .commerce-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 10px;
  }

  .commerce-primary {
    border: 0;
    background: #1ca6bd;
    color: #fff;
    font-weight: 600;
    padding: 7px 12px;
    font-size: 0.9rem;
    border-radius: 4px;
  }

  .commerce-primary:hover {
    background: #168ca0;
  }

  .commerce-secondary {
    border: 1px solid #848484;
    color: #3d3d3d;
    background: transparent;
    font-weight: 600;
    padding: 7px 12px;
    font-size: 0.9rem;
    border-radius: 4px;
    text-decoration: none;
  }

  .commerce-secondary:hover {
    background: #dfdfdf;
  }

  @media (max-width: 576px) {
    .commerce-title {
      font-size: 1.25rem;
    }
  }
</style>
{{/section}}

<div class="commerce-shell">
  <div class="commerce-card">
    <h1 class="commerce-title">Registrar comercio</h1>
    <p class="commerce-subtitle">Completa el formulario para crear tu cuenta de comercio</p>

    {{#if errors.length}}
    <div class="alert alert-danger py-2" role="alert">
      <ul class="mb-0 small">
        {{#each errors}}
        <li>{{this}}</li>
        {{/each}}
      </ul>
    </div>
    {{/if}}

    <form action="/user/register-commerce" method="POST" enctype="multipart/form-data" novalidate>
      <div class="row g-1">
        <div class="col-12">
          <label for="nombre" class="form-label commerce-label">Nombre del comercio</label>
          <input
            id="nombre"
            name="nombre"
            type="text"
            class="form-control commerce-input"
            value="{{formData.nombre}}"
            required
          />
        </div>

        <div class="col-12 col-md-6">
          <label for="telefono" class="form-label commerce-label">Telefono</label>
          <input
            id="telefono"
            name="telefono"
            type="tel"
            class="form-control commerce-input"
            value="{{formData.telefono}}"
            placeholder="8090000000"
            inputmode="numeric"
            pattern="[0-9]{7,15}"
            maxlength="15"
            oninput="this.value = this.value.replace(/[^0-9]/g, '')"
            required
          />
        </div>

        <div class="col-12 col-md-6">
          <label for="correo" class="form-label commerce-label">Correo</label>
          <input
            id="correo"
            name="correo"
            type="email"
            class="form-control commerce-input"
            value="{{formData.correo}}"
            required
          />
        </div>

        <div class="col-12 col-md-6">
          <label for="horaApertura" class="form-label commerce-label">Hora de apertura</label>
          <input
            id="horaApertura"
            name="horaApertura"
            type="time"
            class="form-control commerce-input"
            value="{{formData.horaApertura}}"
            required
          />
        </div>

        <div class="col-12 col-md-6">
          <label for="horaCierre" class="form-label commerce-label">Hora de cierre</label>
          <input
            id="horaCierre"
            name="horaCierre"
            type="time"
            class="form-control commerce-input"
            value="{{formData.horaCierre}}"
            required
          />
        </div>

        <div class="col-12">
          <label for="tipoComercio" class="form-label commerce-label">Tipo de comercio</label>
          <select id="tipoComercio" name="tipoComercio" class="form-select commerce-select" required>
            <option value="">Selecciona un tipo</option>
            {{#each commerceTypes}}
            <option value="{{this._id}}" {{#if (eq ../formData.tipoComercio this._id)}}selected{{/if}}>{{this.name}}</option>
            {{/each}}
          </select>
        </div>

        <div class="col-12">
          <label for="profileImage" class="form-label commerce-label">Logo del comercio</label>
          <input
            id="profileImage"
            name="profileImage"
            type="file"
            class="form-control commerce-input"
            accept="image/*"
            required
          />
        </div>

        <div class="col-12 col-md-6">
          <label for="password" class="form-label commerce-label">Contrasena</label>
          <input
            id="password"
            name="password"
            type="password"
            class="form-control commerce-input"
            minlength="8"
            required
          />
        </div>

        <div class="col-12 col-md-6">
          <label for="confirmPassword" class="form-label commerce-label">Confirmar contrasena</label>
          <input
            id="confirmPassword"
            name="confirmPassword"
            type="password"
            class="form-control commerce-input"
            minlength="8"
            required
          />
        </div>
      </div>

      <div class="commerce-actions">
        <button type="submit" class="commerce-primary">Registrar comercio</button>
        <a href="/user/login" class="commerce-secondary">Volver al login</a>
      </div>
    </form>
  </div>
</div>
