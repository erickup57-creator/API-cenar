{{#section "styles"}}
<style>
  body {
    background: #032f3a;
  }

  main.container {
    max-width: 100%;
    margin-top: 0 !important;
    padding: 0;
  }

  .favorites-shell {
    min-height: calc(100vh - 56px);
    display: grid;
    place-items: start center;
    padding: 42px 16px;
  }

  .favorites-panel {
    width: 100%;
    max-width: 760px;
    background: #ececec;
    border-radius: 10px;
    padding: 22px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.24);
  }

  .favorites-title {
    margin: 0;
    color: #1f1f1f;
    font-size: 1.85rem;
    font-weight: 700;
    line-height: 1.1;
  }

  .favorites-subtitle {
    color: #666;
    font-size: 0.92rem;
    font-weight: 600;
  }

  .favorite-item {
    background: #f8f9fa;
    border: 1px solid #b9c6ce;
    border-radius: 6px;
    padding: 14px;
  }

  .favorite-logo,
  .favorite-placeholder {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
  }

  .favorite-placeholder {
    background: rgba(28, 166, 189, 0.16);
    color: #168ca0;
  }

  .favorite-name {
    color: #1f1f1f;
    font-weight: 700;
    text-decoration: none;
  }

  .favorite-name:hover {
    color: #168ca0;
  }

  .favorite-remove {
    border-radius: 4px;
    font-weight: 600;
  }

  .favorites-empty {
    background: #f8f9fa;
    border: 1px solid #b9c6ce;
    color: #4f4f4f;
    border-radius: 6px;
  }

  @media (max-width: 575.98px) {
    .favorites-shell {
      padding: 24px 12px;
    }

    .favorites-panel {
      padding: 18px;
    }
  }
</style>
{{/section}}

<section class="favorites-shell">
  <div class="favorites-panel">
    <div class="mb-4">
      <h1 class="favorites-title">Mis favoritos</h1>
      <p class="favorites-subtitle mb-0 mt-2">Comercios que has marcado como favoritos.</p>
    </div>

    {{#if errors.length}}
      <div class="alert alert-danger py-2" role="alert">
        {{#each errors}}
          <p class="mb-0">{{this}}</p>
        {{/each}}
      </div>
    {{/if}}

    {{#if success.length}}
      <div class="alert alert-success py-2" role="alert">
        {{#each success}}
          <p class="mb-0">{{this}}</p>
        {{/each}}
      </div>
    {{/if}}

    {{#if hasFavorites}}
      <div class="d-flex flex-column gap-2">
        {{#each favoritesList}}
          <article class="favorite-item">
            <div class="d-flex flex-column flex-sm-row align-items-sm-center gap-3">
              <a href="/client/catalogue/{{this.commerceId._id}}" class="flex-shrink-0">
                {{#if this.commerceId.logoUrl}}
                  <div class="favorite-placeholder d-flex align-items-center justify-content-center">
                    <img
                      src="{{this.commerceId.logoUrl}}"
                      alt="Logo de {{this.commerceId.name}}"
                      class="favorite-logo"
                      onerror="this.classList.add('d-none'); this.nextElementSibling.classList.remove('d-none');"
                    />
                    <i class="bi bi-shop d-none"></i>
                  </div>
                {{else}}
                  <div class="favorite-placeholder d-flex align-items-center justify-content-center">
                    <i class="bi bi-shop"></i>
                  </div>
                {{/if}}
              </a>

              <a href="/client/catalogue/{{this.commerceId._id}}" class="favorite-name flex-grow-1 text-break">
                {{this.commerceId.name}}
              </a>

              <form method="POST" action="/favorite/delete" class="align-self-stretch align-self-sm-center" onsubmit="return confirm('Deseas remover este comercio de favoritos?');">
                <input type="hidden" name="FavoriteId" value="{{this._id}}" />
                <button type="submit" class="btn btn-outline-danger btn-sm favorite-remove w-100">
                  <i class="bi bi-heart-fill me-1"></i>Remover
                </button>
              </form>
            </div>
          </article>
        {{/each}}
      </div>
    {{else}}
      <div class="favorites-empty p-3" role="alert">
        <i class="bi bi-info-circle me-1"></i>No tienes comercios favoritos aun.
      </div>
    {{/if}}
  </div>
</section>
