{{#section "styles"}}
<style>
  body {
    background: #032f3a;
  }

  main.container {
    max-width: 100%;
    margin-top: 0 !important;
    padding: 0;
  }

  .address-shell {
    min-height: calc(100vh - 56px);
    display: grid;
    place-items: start center;
    padding: 42px 16px;
  }

  .address-panel {
    width: 100%;
    max-width: 760px;
    background: #ececec;
    border-radius: 10px;
    padding: 22px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.24);
  }

  .address-title {
    margin: 0;
    color: #1f1f1f;
    font-size: 1.85rem;
    font-weight: 700;
    line-height: 1.1;
  }

  .address-subtitle {
    color: #666;
    font-size: 0.92rem;
    font-weight: 600;
  }

  .address-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 0;
    background: #1ca6bd;
    color: #fff;
    font-weight: 600;
    padding: 9px 12px;
    border-radius: 4px;
    text-decoration: none;
  }

  .address-submit:hover {
    background: #168ca0;
    color: #fff;
  }

  .address-item {
    background: #f8f9fa;
    border: 1px solid #b9c6ce;
    border-radius: 6px;
    padding: 14px;
  }

  .address-icon {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(28, 166, 189, 0.16);
    color: #168ca0;
  }

  .address-action {
    border-radius: 4px;
    font-weight: 600;
  }

  .address-empty {
    background: #f8f9fa;
    border: 1px solid #b9c6ce;
    color: #4f4f4f;
    border-radius: 6px;
  }

  @media (max-width: 575.98px) {
    .address-shell {
      padding: 24px 12px;
    }

    .address-panel {
      padding: 18px;
    }
  }
</style>
{{/section}}

<section class="address-shell">
  <div class="address-panel">
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3 mb-4">
      <div>
        <h1 class="address-title">Mis direcciones</h1>
        <p class="address-subtitle mb-0 mt-2">Direcciones disponibles para tus entregas.</p>
      </div>

      <a href="/address/create" class="address-submit btn-sm align-self-start align-self-sm-center">
        <i class="bi bi-plus-circle me-1"></i>Nueva direccion
      </a>
    </div>

    {{#if errors.length}}
      <div class="alert alert-danger py-2" role="alert">
        {{#each errors}}
          <p class="mb-0">{{this}}</p>
        {{/each}}
      </div>
    {{/if}}

    {{#if success.length}}
      <div class="alert alert-success py-2" role="alert">
        {{#each success}}
          <p class="mb-0">{{this}}</p>
        {{/each}}
      </div>
    {{/if}}

    {{#if hasAddresses}}
      <div class="d-flex flex-column gap-2">
        {{#each addressesList}}
          <article class="address-item">
            <div class="d-flex flex-column flex-sm-row gap-3 align-items-sm-start">
              <div class="address-icon d-flex align-items-center justify-content-center flex-shrink-0">
                <i class="bi bi-geo-alt-fill"></i>
              </div>

              <div class="flex-grow-1" style="min-width: 0;">
                <h2 class="h6 fw-semibold text-dark mb-1 text-break">{{this.name}}</h2>
                <p class="text-muted small mb-0 text-break">{{this.description}}</p>
              </div>

              <div class="d-flex flex-column flex-sm-row gap-2 flex-shrink-0 align-self-stretch align-self-sm-start">
                <a href="/address/edit/{{this._id}}" class="btn btn-outline-secondary btn-sm address-action">
                  <i class="bi bi-pencil me-1"></i>Editar
                </a>

                <form method="POST" action="/address/delete" onsubmit="return confirm('Deseas eliminar esta direccion?');">
                  <input type="hidden" name="AddressId" value="{{this._id}}" />
                  <button type="submit" class="btn btn-outline-danger btn-sm address-action w-100">
                    <i class="bi bi-trash3 me-1"></i>Eliminar
                  </button>
                </form>
              </div>
            </div>
          </article>
        {{/each}}
      </div>
    {{else}}
      <div class="address-empty p-3" role="alert">
        <i class="bi bi-info-circle me-1"></i>No tienes direcciones registradas.
      </div>
    {{/if}}
  </div>
</section>
