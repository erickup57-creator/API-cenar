{{#section "styles"}}
<style>
  body {
    background: #032f3a;
  }

  main.container {
    max-width: 100%;
    margin-top: 0 !important;
    padding: 0;
  }

  .home-shell {
    min-height: calc(100vh - 56px);
    display: grid;
    place-items: start center;
    padding: 42px 16px;
  }

  .home-panel {
    width: 100%;
    max-width: 920px;
    background: #ececec;
    border-radius: 10px;
    padding: 22px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.24);
  }

  .home-title {
    margin: 0;
    color: #1f1f1f;
    font-size: 1.85rem;
    font-weight: 700;
    line-height: 1.1;
  }

  .home-subtitle {
    color: #666;
    font-size: 0.92rem;
    font-weight: 600;
  }

  .commerce-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 12px;
  }

  .commerce-type {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 128px;
    background: #f8f9fa;
    border: 1px solid #b9c6ce;
    border-radius: 6px;
    padding: 14px;
    color: #1f1f1f;
    text-align: center;
    text-decoration: none;
    transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
  }

  .commerce-type:hover {
    border-color: #19a8bd;
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.12);
    color: #1f1f1f;
    transform: translateY(-1px);
  }

  .commerce-icon {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: rgba(28, 166, 189, 0.16);
    color: #168ca0;
    margin-bottom: 10px;
  }

  .commerce-icon img {
    width: 34px;
    height: 34px;
    object-fit: contain;
  }

  .commerce-icon i {
    font-size: 1.7rem;
  }

  .commerce-label {
    font-size: 0.92rem;
    font-weight: 700;
    line-height: 1.25;
  }

  .home-empty {
    background: #f8f9fa;
    border: 1px solid #b9c6ce;
    color: #4f4f4f;
    border-radius: 6px;
  }

  @media (max-width: 575.98px) {
    .home-shell {
      padding: 24px 12px;
    }

    .home-panel {
      padding: 18px;
    }
  }
</style>
{{/section}}

<section class="home-shell">
  <div class="home-panel">
    <div class="mb-4">
      <h1 class="home-title">Hola, {{user.name}}</h1>
      <p class="home-subtitle mb-0 mt-2">Que vas a pedir hoy?</p>
    </div>

    {{#if errors.length}}
      <div class="alert alert-danger py-2" role="alert">
        {{#each errors}}
          <p class="mb-0">{{this}}</p>
        {{/each}}
      </div>
    {{/if}}

    {{#if success.length}}
      <div class="alert alert-success py-2" role="alert">
        {{#each success}}
          <p class="mb-0">{{this}}</p>
        {{/each}}
      </div>
    {{/if}}

    {{#if hasCommerceTypes}}
      <div class="commerce-grid">
        {{#each commerceTypes}}
          <a href="/client/commerces/{{this._id}}" class="commerce-type">
            <div class="commerce-icon d-flex align-items-center justify-content-center">
              {{#if this.iconUrl}}
                <img src="{{this.iconUrl}}" alt="{{this.name}}" />
              {{else}}
                {{#if this.iconClass}}
                  <i class="{{this.iconClass}}"></i>
                {{else}}
                  <i class="bi bi-shop"></i>
                {{/if}}
              {{/if}}
            </div>
            <span class="commerce-label text-break">{{this.description}}</span>
          </a>
        {{/each}}
      </div>
    {{else}}
      <div class="home-empty p-3" role="alert">
        <i class="bi bi-info-circle me-1"></i>No hay tipos de comercios disponibles por el momento.
      </div>
    {{/if}}
  </div>
</section>
