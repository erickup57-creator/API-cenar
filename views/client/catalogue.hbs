{{#section "styles"}}
<style>
  body {
    background: #032f3a;
  }

  main.container {
    max-width: 100%;
    margin-top: 0 !important;
    padding: 0;
  }

  .catalogue-shell {
    min-height: calc(100vh - 56px);
    display: grid;
    place-items: start center;
    padding: 42px 16px;
  }

  .catalogue-panel {
    width: 100%;
    max-width: 1080px;
    background: #ececec;
    border-radius: 10px;
    padding: 22px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.24);
  }

  .catalogue-title {
    margin: 0;
    color: #1f1f1f;
    font-size: 1.85rem;
    font-weight: 700;
    line-height: 1.1;
  }

  .catalogue-back,
  .cart-clear {
    border-radius: 4px;
    font-weight: 600;
    padding: 9px 12px;
  }

  .commerce-logo,
  .commerce-placeholder {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    object-fit: cover;
  }

  .commerce-placeholder {
    background: rgba(28, 166, 189, 0.16);
    color: #168ca0;
  }

  .category-title {
    color: #1f1f1f;
    font-size: 1.05rem;
    font-weight: 700;
    border-bottom: 1px solid #b9c6ce;
    padding-bottom: 8px;
  }

  .product-item,
  .cart-panel {
    background: #f8f9fa;
    border: 1px solid #b9c6ce;
    border-radius: 6px;
  }

  .product-item {
    padding: 12px;
  }

  .product-image,
  .product-placeholder {
    width: 72px;
    height: 72px;
    border-radius: 6px;
    object-fit: cover;
  }

  .product-placeholder {
    background: #e9ecef;
    color: #666;
  }

  .product-price {
    color: #168ca0;
    font-weight: 700;
  }

  .catalogue-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 0;
    background: #1ca6bd;
    color: #fff;
    font-weight: 600;
    padding: 8px 10px;
    border-radius: 4px;
  }

  .catalogue-submit:hover {
    background: #168ca0;
    color: #fff;
  }

  .catalogue-submit:disabled {
    background: #8f9da3;
    color: #fff;
  }

  .cart-remove {
    border-radius: 4px;
    line-height: 1;
  }

  .catalogue-empty {
    background: #f8f9fa;
    border: 1px solid #b9c6ce;
    color: #4f4f4f;
    border-radius: 6px;
  }

  @media (max-width: 575.98px) {
    .catalogue-shell {
      padding: 24px 12px;
    }

    .catalogue-panel {
      padding: 18px;
    }
  }
</style>
{{/section}}

<section class="catalogue-shell">
  <div class="catalogue-panel">
    <div class="d-flex flex-column flex-sm-row align-items-sm-center gap-3 mb-4">
      <a href="/client/dashboard" class="btn btn-outline-secondary catalogue-back align-self-start">
        <i class="bi bi-arrow-left me-1"></i>Volver
      </a>

      {{#if commerce.logoUrl}}
        <div class="commerce-placeholder d-flex align-items-center justify-content-center">
          <img
            src="{{commerce.logoUrl}}"
            alt="Logo de {{commerce.name}}"
            class="commerce-logo"
            onerror="this.classList.add('d-none'); this.nextElementSibling.classList.remove('d-none');"
          />
          <i class="bi bi-shop fs-4 d-none"></i>
        </div>
      {{else}}
        <div class="commerce-placeholder d-flex align-items-center justify-content-center">
          <i class="bi bi-shop fs-4"></i>
        </div>
      {{/if}}

      <h1 class="catalogue-title text-break">{{commerce.name}}</h1>
    </div>

    <div class="row g-4">
      <div class="col-lg-8">
        {{#if hasCategories}}
          {{#each categories}}
            <section class="mb-4">
              <h2 class="category-title mb-2">{{this.name}}</h2>

              <div class="d-flex flex-column gap-2">
                {{#each this.items}}
                  <article class="product-item">
                    <div class="d-flex flex-column flex-sm-row align-items-sm-center gap-3">
                      {{#if this.imageUrl}}
                        <div class="product-placeholder d-flex align-items-center justify-content-center flex-shrink-0">
                          <img
                            src="{{this.imageUrl}}"
                            alt="{{this.name}}"
                            class="product-image"
                            onerror="this.classList.add('d-none'); this.nextElementSibling.classList.remove('d-none');"
                          />
                          <i class="bi bi-bag d-none"></i>
                        </div>
                      {{else}}
                        <div class="product-placeholder d-flex align-items-center justify-content-center flex-shrink-0">
                          <i class="bi bi-bag"></i>
                        </div>
                      {{/if}}

                      <div class="flex-grow-1" style="min-width: 0;">
                        <h3 class="h6 fw-semibold text-dark mb-1 text-break">{{this.name}}</h3>
                        <p class="text-muted small mb-1 text-break">{{this.description}}</p>
                        <span class="product-price">{{this.priceLabel}}</span>
                      </div>

                      {{#if (includes ../../cartIds this._id)}}
                        <button class="catalogue-submit align-self-stretch align-self-sm-center" disabled>
                          Agregado
                        </button>
                      {{else}}
                        <form action="/client/cart/add" method="POST" class="align-self-stretch align-self-sm-center">
                          <input type="hidden" name="productId" value="{{this._id}}" />
                          <input type="hidden" name="name" value="{{this.name}}" />
                          <input type="hidden" name="price" value="{{this.price}}" />
                          <input type="hidden" name="commerceId" value="{{../../commerce._id}}" />
                          <button type="submit" class="catalogue-submit w-100">
                            Agregar
                          </button>
                        </form>
                      {{/if}}
                    </div>
                  </article>
                {{/each}}
              </div>
            </section>
          {{/each}}
        {{else}}
          <div class="catalogue-empty p-3" role="alert">
            <i class="bi bi-info-circle me-1"></i>Este comercio no tiene productos disponibles.
          </div>
        {{/if}}
      </div>

      <div class="col-lg-4">
        <aside class="cart-panel p-3 sticky-lg-top" style="top: 80px;">
          <h2 class="h5 fw-bold mb-3">Mi pedido</h2>

          {{#if cart.hasItems}}
            {{#each cart.items}}
              <div class="d-flex justify-content-between align-items-center gap-2 mb-2 small">
                <span class="text-break">{{this.name}}</span>
                <form action="/client/cart/remove" method="POST">
                  <input type="hidden" name="productId" value="{{this.productId}}" />
                  <input type="hidden" name="commerceId" value="{{../commerce._id}}" />
                  <button type="submit" class="btn btn-outline-danger btn-sm cart-remove py-1 px-2">
                    <i class="bi bi-x"></i>
                  </button>
                </form>
              </div>
            {{/each}}

            <hr />
            <div class="d-flex justify-content-between small">
              <span>Subtotal</span><span>{{cart.subtotalLabel}}</span>
            </div>
            <div class="d-flex justify-content-between small text-muted">
              <span>ITBIS ({{itbisRate}}%)</span><span>{{cart.itbisLabel}}</span>
            </div>
            <div class="d-flex justify-content-between fw-bold mt-1">
              <span>Total</span><span>{{cart.totalLabel}}</span>
            </div>

            <a href="/client/checkout/{{commerce._id}}" class="catalogue-submit w-100 mt-3 text-decoration-none">
              Continuar <i class="bi bi-arrow-right ms-1"></i>
            </a>
            <form action="/client/cart/clear" method="POST" class="mt-2">
              <input type="hidden" name="commerceId" value="{{commerce._id}}" />
              <button type="submit" class="btn btn-outline-secondary cart-clear w-100">
                Vaciar carrito
              </button>
            </form>
          {{else}}
            <p class="text-muted small mb-0">Tu pedido esta vacio.</p>
          {{/if}}
        </aside>
      </div>
    </div>
  </div>
</section>
