{{#section "styles"}}
<style>
  body {
    background: #032f3a;
  }

  main.container {
    max-width: 100%;
    margin-top: 0 !important;
    padding: 0;
  }

  .checkout-shell {
    min-height: calc(100vh - 56px);
    display: grid;
    place-items: start center;
    padding: 42px 16px;
  }

  .checkout-panel {
    width: 100%;
    max-width: 980px;
    background: #ececec;
    border-radius: 10px;
    padding: 22px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.24);
  }

  .checkout-title {
    margin: 0;
    color: #1f1f1f;
    font-size: 1.85rem;
    font-weight: 700;
    line-height: 1.1;
  }

  .checkout-subtitle {
    color: #666;
    font-size: 0.92rem;
    font-weight: 600;
  }

  .checkout-back,
  .checkout-add-address {
    border-radius: 4px;
    font-weight: 600;
    padding: 9px 12px;
  }

  .checkout-card {
    background: #f8f9fa;
    border: 1px solid #b9c6ce;
    border-radius: 6px;
    padding: 16px;
  }

  .address-option {
    background: #fff;
    border: 1px solid #d4dde2;
    border-radius: 6px;
    padding: 14px 14px 14px 42px;
  }

  .address-option:has(input:checked) {
    border-color: #19a8bd;
    box-shadow: 0 0 0 0.18rem rgba(25, 168, 189, 0.18);
  }

  .address-option .form-check-input {
    margin-left: -28px;
  }

  .commerce-logo,
  .commerce-placeholder {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
  }

  .commerce-placeholder {
    background: rgba(28, 166, 189, 0.16);
    color: #168ca0;
  }

  .checkout-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 0;
    background: #1ca6bd;
    color: #fff;
    font-weight: 600;
    padding: 10px 12px;
    border-radius: 4px;
  }

  .checkout-submit:hover {
    background: #168ca0;
    color: #fff;
  }

  .checkout-warning {
    background: #fff8e1;
    border: 1px solid #e0c36c;
    color: #5f4b00;
    border-radius: 6px;
  }

  .checkout-warning a {
    color: #168ca0;
    font-weight: 700;
  }

  @media (max-width: 575.98px) {
    .checkout-shell {
      padding: 24px 12px;
    }

    .checkout-panel {
      padding: 18px;
    }
  }
</style>
{{/section}}

<section class="checkout-shell">
  <div class="checkout-panel">
    <div class="d-flex flex-column flex-sm-row align-items-sm-center gap-3 mb-4">
      <a href="/client/catalogue/{{commerce._id}}" class="btn btn-outline-secondary checkout-back align-self-start">
        <i class="bi bi-arrow-left me-1"></i>Volver
      </a>
      <div>
        <h1 class="checkout-title">Confirmar pedido</h1>
        <p class="checkout-subtitle mb-0 mt-2">Selecciona la direccion de entrega y revisa tu orden.</p>
      </div>
    </div>

    {{#if hasAddresses}}
      <div class="row g-4">
        <div class="col-lg-7">
          <section class="checkout-card">
            <h2 class="h5 fw-bold mb-3">Direccion de entrega</h2>

            <form action="/client/checkout" method="POST" id="checkoutForm">
              <input type="hidden" name="commerceId" value="{{commerce._id}}" />

              <div class="d-flex flex-column gap-2">
                {{#each addresses}}
                  <label class="form-check address-option mb-0" for="addr-{{this._id}}">
                    <input
                      class="form-check-input"
                      type="radio"
                      name="addressId"
                      id="addr-{{this._id}}"
                      value="{{this._id}}"
                      required
                    />
                    <span class="fw-semibold text-dark d-block">{{this.name}}</span>
                    <span class="text-muted small d-block text-break">{{this.description}}</span>
                  </label>
                {{/each}}
              </div>

              <button type="submit" class="checkout-submit w-100 mt-3">
                <i class="bi bi-bag-check me-1"></i>Realizar pedido
              </button>
            </form>
          </section>
        </div>

        <div class="col-lg-5">
          <aside class="checkout-card">
            <div class="d-flex align-items-center gap-3 mb-3">
              {{#if commerce.logoUrl}}
                <div class="commerce-placeholder d-flex align-items-center justify-content-center">
                  <img
                    src="{{commerce.logoUrl}}"
                    alt="Logo de {{commerce.name}}"
                    class="commerce-logo"
                    onerror="this.classList.add('d-none'); this.nextElementSibling.classList.remove('d-none');"
                  />
                  <i class="bi bi-shop d-none"></i>
                </div>
              {{else}}
                <div class="commerce-placeholder d-flex align-items-center justify-content-center">
                  <i class="bi bi-shop"></i>
                </div>
              {{/if}}
              <h2 class="h5 fw-bold mb-0 text-break">{{commerce.name}}</h2>
            </div>

            <div class="d-flex flex-column gap-2 mb-3">
              {{#each cart.items}}
                <div class="d-flex justify-content-between gap-2 small">
                  <span class="text-break">{{this.name}}</span>
                </div>
              {{/each}}
            </div>

            <hr />

            <div class="d-flex justify-content-between small">
              <span>Subtotal</span><span>{{cart.subtotalLabel}}</span>
            </div>
            <div class="d-flex justify-content-between small text-muted">
              <span>ITBIS ({{itbisRate}}%)</span><span>{{cart.itbisLabel}}</span>
            </div>
            <div class="d-flex justify-content-between fw-bold mt-1">
              <span>Total</span><span>{{cart.totalLabel}}</span>
            </div>
          </aside>
        </div>
      </div>
    {{else}}
      <div class="checkout-warning p-3" role="alert">
        <i class="bi bi-exclamation-triangle me-1"></i>No tienes direcciones registradas.
        <a href="/address/create">Agregar una direccion</a>
      </div>
    {{/if}}
  </div>
</section>
