{{#section "styles"}}
<style>
  body {
    background: #032f3a;
  }

  main.container {
    max-width: 100%;
    margin-top: 0 !important;
    padding: 0;
  }

  .address-form-shell {
    min-height: calc(100vh - 56px);
    display: grid;
    place-items: center;
    padding: 42px 16px;
  }

  .address-form-card {
    width: 100%;
    max-width: 480px;
    background: #ececec;
    border-radius: 10px;
    padding: 22px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.24);
  }

  .address-form-title {
    margin: 0 0 18px;
    color: #1f1f1f;
    font-size: 1.85rem;
    font-weight: 700;
    line-height: 1.1;
  }

  .address-input {
    background: #e9ecef;
    border: 1px solid #b9c6ce;
    color: #1e2428;
    padding: 10px 12px;
  }

  .address-input:focus {
    border-color: #19a8bd;
    box-shadow: 0 0 0 0.18rem rgba(25, 168, 189, 0.25);
    background: #f4f7f9;
  }

  .address-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 0;
    background: #1ca6bd;
    color: #fff;
    font-weight: 600;
    padding: 10px 12px;
    border-radius: 4px;
  }

  .address-submit:hover {
    background: #168ca0;
    color: #fff;
  }

  .address-back {
    border-radius: 4px;
    font-weight: 600;
    padding: 9px 12px;
  }

  @media (max-width: 575.98px) {
    .address-form-shell {
      padding: 24px 12px;
    }

    .address-form-card {
      padding: 18px;
    }
  }
</style>
{{/section}}

<section class="address-form-shell">
  <div class="address-form-card">
    <h1 class="address-form-title">
      <i class="bi bi-geo-alt me-2"></i>{{#if editMode}}Editar direccion{{else}}Nueva direccion{{/if}}
    </h1>

    {{#if errors.length}}
      <div class="alert alert-danger py-2" role="alert">
        {{#each errors}}
          <p class="mb-0">{{this}}</p>
        {{/each}}
      </div>
    {{/if}}

    {{#if success.length}}
      <div class="alert alert-success py-2" role="alert">
        {{#each success}}
          <p class="mb-0">{{this}}</p>
        {{/each}}
      </div>
    {{/if}}

    <form method="POST" action="/address/{{#if editMode}}edit{{else}}create{{/if}}" novalidate>
      <div class="mb-3">
        <input
          type="text"
          class="form-control address-input"
          id="Name"
          name="Name"
          value="{{formData.name}}"
          placeholder="Casa, trabajo, universidad"
          aria-label="Nombre"
          required
        />
      </div>

      <div class="mb-3">
        <textarea
          class="form-control address-input"
          id="Description"
          name="Description"
          rows="4"
          placeholder="Calle, numero, sector y referencias"
          aria-label="Descripcion"
          required
        >{{formData.description}}</textarea>
      </div>

      {{#if editMode}}
        <input type="hidden" name="AddressId" value="{{formData.AddressId}}" />
      {{/if}}

      <div class="d-flex gap-2 mt-4">
        <a href="/client/addresses" class="btn btn-outline-secondary address-back w-50">
          <i class="bi bi-arrow-left me-1"></i>Volver
        </a>
        <button type="submit" class="btn address-submit w-50">
          <i class="bi bi-floppy me-1"></i>Guardar
        </button>
      </div>
    </form>
  </div>
</section>
