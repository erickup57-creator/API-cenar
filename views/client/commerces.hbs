{{#section "styles"}}
<style>
  body {
    background: #032f3a;
  }

  main.container {
    max-width: 100%;
    margin-top: 0 !important;
    padding: 0;
  }

  .commerces-shell {
    min-height: calc(100vh - 56px);
    display: grid;
    place-items: start center;
    padding: 42px 16px;
  }

  .commerces-panel {
    width: 100%;
    max-width: 760px;
    background: #ececec;
    border-radius: 10px;
    padding: 22px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.24);
  }

  .commerces-title {
    margin: 0;
    color: #1f1f1f;
    font-size: 1.85rem;
    font-weight: 700;
    line-height: 1.1;
  }

  .commerces-subtitle {
    color: #666;
    font-size: 0.92rem;
    font-weight: 600;
  }

  .commerce-search {
    background: #e9ecef;
    border: 1px solid #b9c6ce;
    color: #1e2428;
    padding: 10px 12px;
  }

  .commerce-search:focus {
    border-color: #19a8bd;
    box-shadow: 0 0 0 0.18rem rgba(25, 168, 189, 0.25);
    background: #f4f7f9;
  }

  .commerce-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 0;
    background: #1ca6bd;
    color: #fff;
    font-weight: 600;
    padding: 10px 12px;
    border-radius: 4px;
  }

  .commerce-submit:hover {
    background: #168ca0;
    color: #fff;
  }

  .commerce-back {
    border-radius: 4px;
    font-weight: 600;
    padding: 9px 12px;
  }

  .commerce-item {
    background: #f8f9fa;
    border: 1px solid #b9c6ce;
    border-radius: 6px;
    padding: 14px;
  }

  .commerce-link {
    color: #1f1f1f;
    text-decoration: none;
  }

  .commerce-link:hover {
    color: #168ca0;
  }

  .commerce-logo,
  .commerce-placeholder {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
  }

  .commerce-placeholder {
    background: rgba(28, 166, 189, 0.16);
    color: #168ca0;
  }

  .commerce-favorite {
    border-radius: 4px;
    font-weight: 600;
  }

  .commerce-empty {
    background: #f8f9fa;
    border: 1px solid #b9c6ce;
    color: #4f4f4f;
    border-radius: 6px;
  }

  @media (max-width: 575.98px) {
    .commerces-shell {
      padding: 24px 12px;
    }

    .commerces-panel {
      padding: 18px;
    }
  }
</style>
{{/section}}

<section class="commerces-shell">
  <div class="commerces-panel">
    <div class="d-flex flex-column flex-sm-row align-items-sm-center gap-3 mb-4">
      <a href="/client/dashboard" class="btn btn-outline-secondary commerce-back align-self-start">
        <i class="bi bi-arrow-left me-1"></i>Volver
      </a>
      <div>
        <h1 class="commerces-title">{{commerceType.name}}</h1>
        <p class="commerces-subtitle mb-0 mt-2">{{total}} comercios disponibles.</p>
      </div>
    </div>

    <form action="/client/commerces/{{commerceType._id}}" method="GET" class="d-flex gap-2 mb-3">
      <input
        type="text"
        class="form-control commerce-search"
        name="search"
        value="{{search}}"
        placeholder="Buscar comercio..."
        aria-label="Buscar comercio"
      />
      <button type="submit" class="commerce-submit">
        <i class="bi bi-search"></i>
      </button>
    </form>

    {{#if hasCommerces}}
      <div class="d-flex flex-column gap-2">
        {{#each commerces}}
          <article class="commerce-item">
            <div class="d-flex flex-column flex-sm-row align-items-sm-center gap-3">
              <a href="/client/catalogue/{{this._id}}" class="commerce-link d-flex align-items-center gap-3 flex-grow-1 text-break">
                {{#if this.logoUrl}}
                  <div class="commerce-placeholder d-flex align-items-center justify-content-center flex-shrink-0">
                    <img
                      src="{{this.logoUrl}}"
                      alt="Logo de {{this.name}}"
                      class="commerce-logo"
                      onerror="this.classList.add('d-none'); this.nextElementSibling.classList.remove('d-none');"
                    />
                    <i class="bi bi-shop d-none"></i>
                  </div>
                {{else}}
                  <div class="commerce-placeholder d-flex align-items-center justify-content-center flex-shrink-0">
                    <i class="bi bi-shop"></i>
                  </div>
                {{/if}}

                <span class="fw-semibold">{{this.name}}</span>
              </a>

              {{#if this.esFavorito}}
                <span class="btn btn-danger btn-sm commerce-favorite disabled align-self-stretch align-self-sm-center">
                  <i class="bi bi-heart-fill"></i>
                </span>
              {{else}}
                <form action="/favorite/create" method="POST" class="align-self-stretch align-self-sm-center">
                  <input type="hidden" name="CommerceId" value="{{this._id}}" />
                  <button type="submit" class="btn btn-outline-danger btn-sm commerce-favorite w-100">
                    <i class="bi bi-heart"></i>
                  </button>
                </form>
              {{/if}}
            </div>
          </article>
        {{/each}}
      </div>
    {{else}}
      <div class="commerce-empty p-3" role="alert">
        <i class="bi bi-info-circle me-1"></i>No se encontraron comercios.
      </div>
    {{/if}}
  </div>
</section>
