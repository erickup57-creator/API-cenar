{{#section "styles"}}
<style>
  body {
    background: #032f3a;
  }

  main.container {
    max-width: 100%;
    margin-top: 0 !important;
    padding: 0;
  }

  .profile-shell {
    min-height: calc(100vh - 56px);
    display: grid;
    place-items: start center;
    padding: 42px 16px;
  }

  .profile-card {
    width: 100%;
    max-width: 640px;
    background: #ececec;
    border-radius: 10px;
    padding: 22px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.24);
  }

  .profile-title {
    margin: 0 0 18px;
    color: #1f1f1f;
    font-size: 1.85rem;
    font-weight: 700;
    line-height: 1.1;
  }

  .profile-photo,
  .profile-photo-empty {
    width: 72px;
    height: 72px;
    border-radius: 50%;
  }

  .profile-photo {
    object-fit: cover;
  }

  .profile-photo-empty {
    background: rgba(28, 166, 189, 0.16);
    color: #168ca0;
  }

  .profile-input {
    background: #e9ecef;
    border: 1px solid #b9c6ce;
    color: #1e2428;
    padding: 10px 12px;
  }

  .profile-input:focus {
    border-color: #19a8bd;
    box-shadow: 0 0 0 0.18rem rgba(25, 168, 189, 0.25);
    background: #f4f7f9;
  }

  .profile-input[readonly] {
    color: #666;
  }

  .profile-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 0;
    background: #1ca6bd;
    color: #fff;
    font-weight: 600;
    padding: 10px 12px;
    border-radius: 4px;
  }

  .profile-submit:hover {
    background: #168ca0;
    color: #fff;
  }

  .profile-back {
    border-radius: 4px;
    font-weight: 600;
    padding: 9px 12px;
  }

  @media (max-width: 575.98px) {
    .profile-shell {
      padding: 24px 12px;
    }

    .profile-card {
      padding: 18px;
    }
  }
</style>
{{/section}}

<section class="profile-shell">
  <div class="profile-card">
    <h1 class="profile-title">
      <i class="bi bi-person-circle me-2"></i>Mi perfil
    </h1>

    {{#if errors.length}}
      <div class="alert alert-danger py-2" role="alert">
        <ul class="mb-0 small">
          {{#each errors}}
            <li>{{this}}</li>
          {{/each}}
        </ul>
      </div>
    {{/if}}

    {{#if success}}
      <div class="alert alert-success py-2" role="alert">
        <i class="bi bi-check-circle me-1"></i>Perfil actualizado correctamente.
      </div>
    {{/if}}

    <form action="/client/profile" method="POST" enctype="multipart/form-data" novalidate>
      <div class="d-flex align-items-center gap-3 mb-3">
        {{#if profileImageUrl}}
          <img src="{{profileImageUrl}}" alt="Foto actual" class="profile-photo border" />
        {{else}}
          <div class="profile-photo-empty d-flex align-items-center justify-content-center">
            <i class="bi bi-person fs-2"></i>
          </div>
        {{/if}}

        <div style="min-width: 0;">
          <div class="fw-semibold text-dark text-break">{{formData.name}} {{formData.lastName}}</div>
          <div class="text-muted small text-break">{{formData.email}}</div>
        </div>
      </div>

      <div class="row g-2">
        <div class="col-12 col-md-6">
          <input
            type="text"
            class="form-control profile-input"
            id="name"
            name="name"
            value="{{formData.name}}"
            placeholder="Nombre"
            aria-label="Nombre"
            required
          />
        </div>

        <div class="col-12 col-md-6">
          <input
            type="text"
            class="form-control profile-input"
            id="lastName"
            name="lastName"
            value="{{formData.lastName}}"
            placeholder="Apellido"
            aria-label="Apellido"
            required
          />
        </div>

        <div class="col-12 col-md-6">
          <input
            type="text"
            class="form-control profile-input"
            id="username"
            value="{{formData.username}}"
            placeholder="Usuario"
            aria-label="Usuario"
            readonly
          />
        </div>

        <div class="col-12 col-md-6">
          <input
            type="email"
            class="form-control profile-input"
            id="email"
            value="{{formData.email}}"
            placeholder="Correo"
            aria-label="Correo"
            readonly
          />
        </div>

        <div class="col-12">
          <input
            type="tel"
            class="form-control profile-input"
            id="phone"
            name="phone"
            value="{{formData.phone}}"
            placeholder="Telefono"
            aria-label="Telefono"
            inputmode="numeric"
            pattern="[0-9]{7,15}"
            maxlength="15"
            oninput="this.value = this.value.replace(/[^0-9]/g, '')"
            required
          />
        </div>

        <div class="col-12">
          <input
            type="file"
            class="form-control profile-input"
            id="profileImage"
            name="profileImage"
            accept="image/*"
            aria-label="Foto de perfil"
          />
        </div>
      </div>

      <div class="d-flex gap-2 mt-4">
        <a href="/client/dashboard" class="btn btn-outline-secondary profile-back w-50">
          <i class="bi bi-arrow-left me-1"></i>Volver
        </a>
        <button type="submit" class="btn profile-submit w-50">
          <i class="bi bi-floppy me-1"></i>Guardar
        </button>
      </div>
    </form>
  </div>
</section>
