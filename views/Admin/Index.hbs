<section class="admin-shell">
  <div class="admin-panel">
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3 mb-4">
      <div>
        <h1 class="admin-title">Administradores</h1>
        <p class="admin-subtitle mb-0 mt-2">Gestiona las cuentas administrativas del sistema.</p>
      </div>
      <a class="admin-submit align-self-start align-self-sm-center" href="/Admin/create">
        <i class="bi bi-plus-circle me-1"></i>Nuevo administrador
      </a>
    </div>

    {{#if hasAdmin}}
      <div class="admin-grid">
        {{#each adminList}}
          <article class="admin-item">
            <div class="d-flex gap-3 align-items-start mb-3">
              <div class="admin-icon d-flex align-items-center justify-content-center flex-shrink-0">
                <i class="bi bi-person-gear fs-4"></i>
              </div>
              <div style="min-width: 0;">
                <h2 class="h6 fw-bold text-dark mb-1 text-break">{{this.name}} {{this.lastName}}</h2>
                <p class="text-muted small mb-0 text-break">{{this.email}}</p>
              </div>
            </div>

            <div class="admin-divider pt-3">
              <div class="d-flex justify-content-between gap-2 small mb-2">
                <span>Usuario</span>
                <strong class="text-break text-end">{{this.username}}</strong>
              </div>
              <div class="d-flex justify-content-between gap-2 small mb-3">
                <span>Cedula</span>
                <strong>{{this.cedula}}</strong>
              </div>

              <div class="d-flex justify-content-between align-items-center gap-2 mb-3">
                {{#if this.isActive}}
                  <span class="admin-status admin-status-active">Activo</span>
                {{else}}
                  <span class="admin-status admin-status-inactive">Inactivo</span>
                {{/if}}
              </div>

              <div class="d-flex flex-column flex-sm-row gap-2">
                {{#if this.canEdit}}
                  <a href="/Admin/edit/{{this._id}}" class="btn btn-outline-secondary btn-sm admin-action flex-fill">
                    <i class="bi bi-pencil me-1"></i>Editar
                  </a>
                {{else}}
                  <span class="text-muted small align-self-center flex-fill">Tu cuenta</span>
                {{/if}}

                {{#if this.canToggleStatus}}
                  <form action="/Admin/status/{{this._id}}" method="post" class="flex-fill">
                    <input type="hidden" name="isActive" value="{{#if this.isActive}}false{{else}}true{{/if}}">
                    <button type="submit" class="btn btn-sm {{#if this.isActive}}btn-outline-danger{{else}}btn-outline-success{{/if}} admin-action w-100" onclick="return confirm('Seguro que deseas cambiar el estado de este administrador?')">
                      {{#if this.isActive}}Inactivar{{else}}Activar{{/if}}
                    </button>
                  </form>
                {{/if}}
              </div>
            </div>
          </article>
        {{/each}}
      </div>
    {{else}}
      <div class="admin-empty p-3" role="alert">
        <i class="bi bi-info-circle me-1"></i>No hay administradores.
      </div>
    {{/if}}
  </div>
</section>
