<section class="commerce-shell">
  <div class="commerce-panel commerce-panel-narrow">
    <h1 class="commerce-title mb-4">
      <i class="bi bi-person-badge me-2"></i>Perfil del comercio
    </h1>

    {{#each successMessages}}
      <div class="alert alert-success py-2 mb-2" role="alert">{{this}}</div>
    {{/each}}

    {{#if errors.length}}
      <div class="alert alert-danger py-2 mb-3" role="alert">
        <ul class="mb-0 small">
          {{#each errors}}
            <li>{{this}}</li>
          {{/each}}
        </ul>
      </div>
    {{/if}}

    <form action="/commerce/profile" method="post" enctype="multipart/form-data" novalidate>
      <div class="d-flex align-items-center gap-3 mb-3">
        {{#if profileImageUrl}}
          <img src="{{profileImageUrl}}" alt="Logo actual del comercio" class="commerce-logo commerce-logo-lg border" />
        {{else}}
          <div class="commerce-placeholder commerce-placeholder-lg d-flex align-items-center justify-content-center">
            <i class="bi bi-shop fs-2"></i>
          </div>
        {{/if}}

        <div>
          <div class="fw-semibold text-dark">Logo del comercio</div>
          <div class="text-muted small">Informacion visible para clientes</div>
        </div>
      </div>

      <div class="row g-2">
        <div class="col-12">
          <label for="profileImage" class="form-label mb-1">Logo del comercio</label>
          <input id="profileImage" name="profileImage" type="file" class="form-control commerce-input" accept="image/*" aria-label="Logo del comercio" />
        </div>

        <div class="col-12 col-md-6">
          <label for="openingTime" class="form-label mb-1">Hora de apertura</label>
          <input id="openingTime" name="openingTime" type="time" class="form-control commerce-input" value="{{formData.openingTime}}" aria-label="Hora de apertura" required />
        </div>

        <div class="col-12 col-md-6">
          <label for="closingTime" class="form-label mb-1">Hora de cierre</label>
          <input id="closingTime" name="closingTime" type="time" class="form-control commerce-input" value="{{formData.closingTime}}" aria-label="Hora de cierre" required />
        </div>

        <div class="col-12 col-md-6">
          <label for="phone" class="form-label mb-1">Telefono</label>
          <input id="phone" name="phone" type="tel" class="form-control commerce-input" value="{{formData.phone}}" placeholder="Telefono" aria-label="Telefono" inputmode="numeric" pattern="[0-9]{7,15}" maxlength="15" oninput="this.value = this.value.replace(/[^0-9]/g, '')" required />
        </div>

        <div class="col-12 col-md-6">
          <label for="email" class="form-label mb-1">Correo</label>
          <input id="email" name="email" type="email" class="form-control commerce-input" value="{{formData.email}}" placeholder="Correo" aria-label="Correo" required />
        </div>
      </div>

      <div class="d-flex gap-2 mt-4">
        <a href="/commerce/dashboard" class="btn btn-outline-secondary commerce-back w-50">
          <i class="bi bi-arrow-left me-1"></i>Volver
        </a>
        <button type="submit" class="btn commerce-submit w-50">
          <i class="bi bi-floppy me-1"></i>Guardar
        </button>
      </div>
    </form>
  </div>
</section>
