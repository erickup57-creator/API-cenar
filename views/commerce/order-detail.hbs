<section class="commerce-shell">
  <div class="commerce-panel">
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3 mb-4">
      <h1 class="commerce-title">Detalle del pedido</h1>
      <a href="/commerce/dashboard" class="btn btn-outline-secondary commerce-back align-self-start align-self-sm-center">
        <i class="bi bi-arrow-left me-1"></i>Volver
      </a>
    </div>

    {{#each successMessages}}
      <div class="alert alert-success py-2 mb-2" role="alert">{{this}}</div>
    {{/each}}

    {{#each errorMessages}}
      <div class="alert alert-danger py-2 mb-2" role="alert">{{this}}</div>
    {{/each}}

    {{#if loadError}}
      <div class="alert alert-danger py-2" role="alert">No se pudo cargar el detalle del pedido.</div>
    {{/if}}

    {{#if notFound}}
      <div class="alert alert-warning py-2 mb-3" role="alert">
        El pedido no existe o no pertenece al comercio logueado.
      </div>
    {{/if}}

    {{#if order}}
      <section class="commerce-card mb-3">
        <div class="d-flex flex-column flex-sm-row gap-3 align-items-sm-center">
          {{#if order.commerceLogoUrl}}
            <img src="{{order.commerceLogoUrl}}" alt="Logo {{order.commerceName}}" class="commerce-logo flex-shrink-0" />
          {{else}}
            <div class="commerce-placeholder d-flex align-items-center justify-content-center flex-shrink-0">
              <i class="bi bi-shop"></i>
            </div>
          {{/if}}

          <div class="flex-grow-1" style="min-width: 0;">
            <h2 class="h5 fw-bold mb-2 text-break">{{order.commerceName}}</h2>
            <div class="d-flex flex-column flex-sm-row gap-2 align-items-sm-center">
              {{#if (eq order.status "pendiente")}}
                <span class="badge text-bg-warning align-self-start">Pendiente</span>
              {{/if}}
              {{#if (eq order.status "en proceso")}}
                <span class="badge text-bg-primary align-self-start">En proceso</span>
              {{/if}}
              {{#if (eq order.status "completado")}}
                <span class="badge text-bg-success align-self-start">Completado</span>
              {{/if}}
              <span class="text-muted small">{{order.createdAtLabel}}</span>
            </div>
          </div>
        </div>
      </section>

      <section class="commerce-card p-0 mb-3">
        <div class="p-3 border-bottom">
          <h2 class="h5 fw-bold mb-0">Productos del pedido</h2>
        </div>

        {{#if hasProducts}}
          {{#each productsList}}
            <div class="commerce-row d-flex align-items-center gap-3 p-3">
              {{#if imageUrl}}
                <img src="{{imageUrl}}" alt="Producto {{name}}" class="commerce-thumb flex-shrink-0" />
              {{else}}
                <div class="commerce-placeholder d-flex align-items-center justify-content-center flex-shrink-0">
                  <i class="bi bi-image"></i>
                </div>
              {{/if}}

              <span class="flex-grow-1 text-dark text-break">{{name}}</span>
              <span class="text-muted small">{{priceLabel}}</span>
            </div>
          {{/each}}
        {{else}}
          <div class="p-3">
            <p class="mb-0">Este pedido no tiene productos.</p>
          </div>
        {{/if}}
      </section>

      <section class="commerce-card mb-3">
        <div class="d-flex justify-content-between gap-2 mb-2">
          <strong>Total del pedido</strong>
          <strong>{{order.totalLabel}}</strong>
        </div>
        {{#if order.assignedDeliveryName}}
          <div class="text-muted small text-break">
            <strong>Delivery asignado:</strong> {{order.assignedDeliveryName}}
          </div>
        {{/if}}
      </section>

      {{#if canAssignDelivery}}
        <section class="commerce-card">
          <h2 class="h5 fw-bold mb-3">Asignar delivery</h2>
          <form action="/commerce/orders/{{order.id}}/assign-delivery" method="post">
            <button type="submit" class="commerce-submit w-100">
              <i class="bi bi-truck me-1"></i>Asignar delivery y pasar a en proceso
            </button>
          </form>
        </section>
      {{/if}}
    {{/if}}
  </div>
</section>
