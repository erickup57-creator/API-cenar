<section class="commerce-shell">
  <div class="commerce-panel commerce-panel-narrow">
    <h1 class="commerce-title mb-4">{{title}}</h1>

    {{#if errors.length}}
      <div class="alert alert-danger py-2 mb-3" role="alert">
        <ul class="mb-0 small">
          {{#each errors}}
            <li>{{this}}</li>
          {{/each}}
        </ul>
      </div>
    {{/if}}

    <form action="{{formAction}}" method="post" novalidate>
      <div class="mb-3">
        <input
          id="name"
          name="name"
          type="text"
          class="form-control commerce-input"
          value="{{formData.name}}"
          placeholder="Nombre de la categoria"
          aria-label="Nombre de la categoria"
          required
        />
      </div>

      <div class="mb-3">
        <textarea
          id="description"
          name="description"
          class="form-control commerce-input"
          rows="4"
          placeholder="Descripcion"
          aria-label="Descripcion"
          required
        >{{formData.description}}</textarea>
      </div>

      <div class="d-flex gap-2 mt-4">
        <a href="{{backHref}}" class="btn btn-outline-secondary commerce-back w-50">
          <i class="bi bi-arrow-left me-1"></i>Volver
        </a>
        <button type="submit" class="btn commerce-submit w-50">{{submitLabel}}</button>
      </div>
    </form>
  </div>
</section>
