<section class="commerce-shell">
  <div class="commerce-panel">
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3 mb-4">
      <div>
        <h1 class="commerce-title">Mantenimiento de categorias</h1>
        <p class="commerce-subtitle mb-0 mt-2">Organiza los productos de tu comercio.</p>
      </div>
      <a href="/commerce/categories/new" class="commerce-submit align-self-start align-self-sm-center">
        <i class="bi bi-plus-circle me-1"></i>Crear categoria
      </a>
    </div>

    {{#each successMessages}}
      <div class="alert alert-success py-2 mb-2" role="alert">{{this}}</div>
    {{/each}}

    {{#if errors.length}}
      <div class="alert alert-danger py-2 mb-3" role="alert">
        <ul class="mb-0 small">
          {{#each errors}}
            <li>{{this}}</li>
          {{/each}}
        </ul>
      </div>
    {{/if}}

    {{#if hasCategories}}
      <div class="d-flex flex-column gap-2">
        {{#each categoriesList}}
          <article class="commerce-item">
            <div class="d-flex flex-column flex-md-row justify-content-between gap-3">
              <div style="min-width: 0;">
                <h2 class="h6 fw-semibold text-dark mb-1 text-break">{{name}}</h2>
                <p class="text-muted small mb-1 text-break">{{description}}</p>
                <span class="commerce-meta">{{productsCount}} productos asignados</span>
              </div>

              <div class="d-flex flex-column flex-sm-row gap-2 align-self-stretch align-self-md-start">
                <a href="/commerce/categories/{{id}}/edit" class="btn btn-outline-secondary btn-sm commerce-action">
                  <i class="bi bi-pencil me-1"></i>Editar
                </a>
                <a href="/commerce/categories/{{id}}/delete" class="btn btn-outline-danger btn-sm commerce-action">
                  <i class="bi bi-trash3 me-1"></i>Eliminar
                </a>
              </div>
            </div>
          </article>
        {{/each}}
      </div>
    {{else}}
      <div class="commerce-empty p-3" role="alert">
        <i class="bi bi-info-circle me-1"></i>Aun no has creado categorias en este comercio.
      </div>
    {{/if}}
  </div>
</section>
