<section class="commerce-shell">
  <div class="commerce-panel commerce-panel-narrow">
    <h1 class="commerce-title mb-4">{{title}}</h1>

    {{#if errors.length}}
      <div class="alert alert-danger py-2 mb-3" role="alert">
        <ul class="mb-0 small">
          {{#each errors}}
            <li>{{this}}</li>
          {{/each}}
        </ul>
      </div>
    {{/if}}

    <form action="{{formAction}}" method="post" enctype="multipart/form-data" novalidate>
      <div class="row g-2">
        <div class="col-12">
          <input
            id="name"
            name="name"
            type="text"
            class="form-control commerce-input"
            value="{{formData.name}}"
            placeholder="Nombre del producto"
            aria-label="Nombre del producto"
            required
          />
        </div>

        <div class="col-12">
          <input
            id="description"
            name="description"
            type="text"
            class="form-control commerce-input"
            value="{{formData.description}}"
            placeholder="Descripcion"
            aria-label="Descripcion"
            required
          />
        </div>

        <div class="col-12 col-md-6">
          <input
            id="price"
            name="price"
            type="number"
            class="form-control commerce-input"
            min="0.01"
            step="0.01"
            value="{{formData.price}}"
            placeholder="Precio"
            aria-label="Precio del producto"
            required
          />
        </div>

        <div class="col-12 col-md-6">
          <select id="categoryId" name="categoryId" class="form-select commerce-input" aria-label="Categoria" required>
            <option value="">Selecciona una categoria</option>
            {{#each categoriesOptions}}
              <option value="{{id}}" {{#if (eq id ../formData.categoryId)}}selected{{/if}}>{{name}}</option>
            {{/each}}
          </select>
          {{#unless hasCategories}}
            <small class="text-muted">No hay categorias creadas para este comercio.</small>
          {{/unless}}
        </div>

        <div class="col-12">
          <input
            id="productImage"
            name="productImage"
            type="file"
            class="form-control commerce-input"
            accept="image/*"
            aria-label="Foto del producto"
            {{#if requireImage}}required{{/if}}
          />
        </div>

        {{#if currentImageUrl}}
          <div class="col-12">
            <div class="commerce-card d-inline-flex flex-column gap-2">
              <span class="commerce-meta">Imagen actual</span>
              <img src="{{currentImageUrl}}" alt="Imagen actual del producto" class="commerce-logo commerce-logo-lg border" />
            </div>
          </div>
        {{/if}}
      </div>

      <div class="d-flex gap-2 mt-4">
        <a href="{{backHref}}" class="btn btn-outline-secondary commerce-back w-50">
          <i class="bi bi-arrow-left me-1"></i>Volver
        </a>
        <button type="submit" class="btn commerce-submit w-50">{{submitLabel}}</button>
      </div>
    </form>
  </div>
</section>
