<section class="commerce-shell">
  <div class="commerce-panel commerce-panel-narrow">
    <h1 class="commerce-title mb-4">Eliminar producto</h1>

    <div class="commerce-card mb-3">
      <p class="mb-3">Estas seguro que deseas eliminar este producto?</p>

      <div class="mb-3">
        <div><strong>Nombre:</strong> {{productName}}</div>
        <div><strong>Descripcion:</strong> {{productDescription}}</div>
      </div>

      <div class="d-flex gap-2">
        <a href="{{backHref}}" class="btn btn-outline-secondary commerce-back w-50">
          <i class="bi bi-arrow-left me-1"></i>Cancelar
        </a>
        <form action="{{formAction}}" method="post" class="w-50">
          <button type="submit" class="btn btn-danger commerce-danger w-100">
            <i class="bi bi-trash3 me-1"></i>Eliminar
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
