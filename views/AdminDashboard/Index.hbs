<section class="admin-shell">
  <div class="admin-panel">
    <div class="mb-4">
      <h1 class="admin-title">Dashboard administrativo</h1>
      <p class="admin-subtitle mb-0 mt-2">Resumen general de actividad y usuarios.</p>
    </div>

    <div class="admin-stat-grid">
      <article class="admin-card admin-stat">
        <div class="d-flex align-items-center gap-3 mb-3">
          <div class="admin-icon d-flex align-items-center justify-content-center">
            <i class="bi bi-receipt fs-4"></i>
          </div>
          <h2 class="h6 fw-bold mb-0 text-dark">Pedidos totales</h2>
        </div>
        <div class="display-6 fw-bold text-dark">{{totalOrders}}</div>
      </article>

      <article class="admin-card admin-stat">
        <div class="d-flex align-items-center gap-3 mb-3">
          <div class="admin-icon d-flex align-items-center justify-content-center">
            <i class="bi bi-calendar-check fs-4"></i>
          </div>
          <h2 class="h6 fw-bold mb-0 text-dark">Pedidos de hoy</h2>
        </div>
        <div class="display-6 fw-bold text-dark">{{todayOrders}}</div>
      </article>

      <article class="admin-card admin-stat">
        <div class="d-flex align-items-center gap-3 mb-3">
          <div class="admin-icon d-flex align-items-center justify-content-center">
            <i class="bi bi-box-seam fs-4"></i>
          </div>
          <h2 class="h6 fw-bold mb-0 text-dark">Productos creados</h2>
        </div>
        <div class="display-6 fw-bold text-dark">{{totalProducts}}</div>
      </article>

      <article class="admin-card admin-stat">
        <div class="d-flex align-items-center gap-3 mb-3">
          <div class="admin-icon d-flex align-items-center justify-content-center">
            <i class="bi bi-shop fs-4"></i>
          </div>
          <h2 class="h6 fw-bold mb-0 text-dark">Comercios</h2>
        </div>
        <div class="d-flex justify-content-between small mb-2">
          <span>Activos</span>
          <strong>{{activeCommerces}}</strong>
        </div>
        <div class="d-flex justify-content-between small">
          <span>Inactivos</span>
          <strong>{{inactiveCommerces}}</strong>
        </div>
      </article>

      <article class="admin-card admin-stat">
        <div class="d-flex align-items-center gap-3 mb-3">
          <div class="admin-icon d-flex align-items-center justify-content-center">
            <i class="bi bi-people fs-4"></i>
          </div>
          <h2 class="h6 fw-bold mb-0 text-dark">Clientes</h2>
        </div>
        <div class="d-flex justify-content-between small mb-2">
          <span>Activos</span>
          <strong>{{activeClients}}</strong>
        </div>
        <div class="d-flex justify-content-between small">
          <span>Inactivos</span>
          <strong>{{inactiveClients}}</strong>
        </div>
      </article>

      <article class="admin-card admin-stat">
        <div class="d-flex align-items-center gap-3 mb-3">
          <div class="admin-icon d-flex align-items-center justify-content-center">
            <i class="bi bi-truck fs-4"></i>
          </div>
          <h2 class="h6 fw-bold mb-0 text-dark">Delivery</h2>
        </div>
        <div class="d-flex justify-content-between small mb-2">
          <span>Activos</span>
          <strong>{{activeDeliveries}}</strong>
        </div>
        <div class="d-flex justify-content-between small">
          <span>Inactivos</span>
          <strong>{{inactiveDeliveries}}</strong>
        </div>
      </article>
    </div>
  </div>
</section>
