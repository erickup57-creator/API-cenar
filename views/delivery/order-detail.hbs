{{#section "styles"}}
<style>
  body {
    background: #032f3a;
  }

  main.container {
    max-width: 100%;
    margin-top: 0 !important;
    padding: 0;
  }

  .order-detail-shell {
    min-height: calc(100vh - 56px);
    display: grid;
    place-items: start center;
    padding: 42px 16px;
  }

  .order-detail-panel {
    width: 100%;
    max-width: 920px;
    background: #ececec;
    border-radius: 10px;
    padding: 22px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.24);
  }

  .order-detail-title {
    margin: 0;
    color: #1f1f1f;
    font-size: 1.85rem;
    font-weight: 700;
    line-height: 1.1;
  }

  .order-back,
  .complete-submit {
    border-radius: 4px;
    font-weight: 600;
    padding: 9px 12px;
  }

  .detail-card,
  .product-list {
    background: #f8f9fa;
    border: 1px solid #b9c6ce;
    border-radius: 6px;
  }

  .detail-card {
    padding: 16px;
  }

  .commerce-logo,
  .commerce-placeholder {
    width: 58px;
    height: 58px;
    border-radius: 6px;
    object-fit: cover;
  }

  .commerce-placeholder,
  .product-placeholder {
    background: rgba(28, 166, 189, 0.16);
    color: #168ca0;
  }

  .product-row {
    padding: 12px;
    border-bottom: 1px solid #d4dde2;
  }

  .product-row:last-child {
    border-bottom: 0;
  }

  .product-image,
  .product-placeholder {
    width: 50px;
    height: 50px;
    border-radius: 6px;
    object-fit: cover;
  }

  .complete-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 0;
    background: #1ca6bd;
    color: #fff;
    padding: 10px 12px;
  }

  .complete-submit:hover {
    background: #168ca0;
    color: #fff;
  }

  .order-empty {
    background: #f8f9fa;
    border: 1px solid #b9c6ce;
    color: #4f4f4f;
    border-radius: 6px;
  }

  @media (max-width: 575.98px) {
    .order-detail-shell {
      padding: 24px 12px;
    }

    .order-detail-panel {
      padding: 18px;
    }
  }
</style>
{{/section}}

<section class="order-detail-shell">
  <div class="order-detail-panel">
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3 mb-4">
      <h1 class="order-detail-title">Detalle del pedido</h1>
      <a href="/delivery/dashboard" class="btn btn-outline-secondary order-back align-self-start align-self-sm-center">
        <i class="bi bi-arrow-left me-1"></i>Volver
      </a>
    </div>

    {{#each successMessages}}
      <div class="alert alert-success py-2 mb-2" role="alert">{{this}}</div>
    {{/each}}

    {{#each errorMessages}}
      <div class="alert alert-danger py-2 mb-2" role="alert">{{this}}</div>
    {{/each}}

    {{#if loadError}}
      <div class="alert alert-danger py-2" role="alert">No se pudo cargar el detalle del pedido.</div>
    {{/if}}

    {{#if notFound}}
      <div class="alert alert-warning py-2 mb-3" role="alert">
        El pedido no existe o no pertenece al delivery logueado.
      </div>
    {{/if}}

    {{#if order}}
      <section class="detail-card mb-3">
        <div class="d-flex flex-column flex-sm-row gap-3 align-items-sm-center">
          {{#if order.commerceLogoUrl}}
            <img src="{{order.commerceLogoUrl}}" alt="Logo {{order.commerceName}}" class="commerce-logo flex-shrink-0" />
          {{else}}
            <div class="commerce-placeholder d-flex align-items-center justify-content-center flex-shrink-0">
              <i class="bi bi-shop"></i>
            </div>
          {{/if}}

          <div class="flex-grow-1" style="min-width: 0;">
            <h2 class="h5 fw-bold mb-2 text-break">{{order.commerceName}}</h2>
            <div class="d-flex flex-column flex-sm-row gap-2 align-items-sm-center">
              <span class="badge {{order.statusBadgeClass}} align-self-start">{{order.statusLabel}}</span>
              <span class="text-muted small">{{order.createdAtLabel}}</span>
            </div>
          </div>
        </div>
      </section>

      <section class="product-list mb-3">
        <div class="p-3 border-bottom">
          <h2 class="h5 fw-bold mb-0">Productos del pedido</h2>
        </div>

        {{#if hasProducts}}
          {{#each productsList}}
            <div class="product-row d-flex align-items-center gap-3">
              {{#if imageUrl}}
                <img src="{{imageUrl}}" alt="Producto {{name}}" class="product-image flex-shrink-0" />
              {{else}}
                <div class="product-placeholder d-flex align-items-center justify-content-center flex-shrink-0">
                  <i class="bi bi-image"></i>
                </div>
              {{/if}}

              <span class="flex-grow-1 text-dark text-break">{{name}}</span>
              <span class="text-muted small">{{priceLabel}}</span>
            </div>
          {{/each}}
        {{else}}
          <div class="p-3">
            <p class="mb-0">Este pedido no tiene productos.</p>
          </div>
        {{/if}}
      </section>

      <section class="detail-card mb-3">
        <div class="d-flex justify-content-between gap-2 mb-2">
          <strong>Total del pedido</strong>
          <strong>{{order.totalLabel}}</strong>
        </div>
        {{#unless (eq order.status "completado")}}
          <div class="text-muted small text-break">
            <strong>Direccion de entrega:</strong> {{order.deliveryAddressLabel}}
          </div>
        {{/unless}}
      </section>

      {{#if canCompleteOrder}}
        <form action="/delivery/orders/{{order.id}}/complete" method="post">
          <button type="submit" class="complete-submit w-100">
            <i class="bi bi-check-circle me-1"></i>Completar pedido
          </button>
        </form>
      {{/if}}
    {{/if}}
  </div>
</section>
