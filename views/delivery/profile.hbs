{{#section "styles"}}
<style>
  body {
    background: #032f3a;
  }

  main.container {
    max-width: 100%;
    margin-top: 0 !important;
    padding: 0;
  }

  .delivery-profile-shell {
    min-height: calc(100vh - 56px);
    display: grid;
    place-items: start center;
    padding: 42px 16px;
  }

  .delivery-profile-card {
    width: 100%;
    max-width: 640px;
    background: #ececec;
    border-radius: 10px;
    padding: 22px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.24);
  }

  .delivery-profile-title {
    margin: 0 0 18px;
    color: #1f1f1f;
    font-size: 1.85rem;
    font-weight: 700;
    line-height: 1.1;
  }

  .delivery-photo,
  .delivery-photo-empty {
    width: 72px;
    height: 72px;
    border-radius: 50%;
  }

  .delivery-photo {
    object-fit: cover;
  }

  .delivery-photo-empty {
    background: rgba(28, 166, 189, 0.16);
    color: #168ca0;
  }

  .delivery-input {
    background: #e9ecef;
    border: 1px solid #b9c6ce;
    color: #1e2428;
    padding: 10px 12px;
  }

  .delivery-input:focus {
    border-color: #19a8bd;
    box-shadow: 0 0 0 0.18rem rgba(25, 168, 189, 0.25);
    background: #f4f7f9;
  }

  .delivery-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 0;
    background: #1ca6bd;
    color: #fff;
    font-weight: 600;
    padding: 10px 12px;
    border-radius: 4px;
  }

  .delivery-submit:hover {
    background: #168ca0;
    color: #fff;
  }

  .delivery-back {
    border-radius: 4px;
    font-weight: 600;
    padding: 9px 12px;
  }

  @media (max-width: 575.98px) {
    .delivery-profile-shell {
      padding: 24px 12px;
    }

    .delivery-profile-card {
      padding: 18px;
    }
  }
</style>
{{/section}}

<section class="delivery-profile-shell">
  <div class="delivery-profile-card">
    <h1 class="delivery-profile-title">
      <i class="bi bi-person-circle me-2"></i>Perfil del delivery
    </h1>

    {{#each successMessages}}
      <div class="alert alert-success py-2 mb-2" role="alert">{{this}}</div>
    {{/each}}

    {{#if errors.length}}
      <div class="alert alert-danger py-2 mb-3" role="alert">
        <ul class="mb-0 small">
          {{#each errors}}
            <li>{{this}}</li>
          {{/each}}
        </ul>
      </div>
    {{/if}}

    <form action="/delivery/profile" method="post" enctype="multipart/form-data" novalidate>
      <div class="d-flex align-items-center gap-3 mb-3">
        {{#if profileImageUrl}}
          <img src="{{profileImageUrl}}" alt="Foto de perfil actual" class="delivery-photo border" />
        {{else}}
          <div class="delivery-photo-empty d-flex align-items-center justify-content-center">
            <i class="bi bi-person fs-2"></i>
          </div>
        {{/if}}

        <div style="min-width: 0;">
          <div class="fw-semibold text-dark text-break">{{formData.name}} {{formData.lastName}}</div>
          <div class="text-muted small">Delivery</div>
        </div>
      </div>

      <div class="row g-2">
        <div class="col-12">
          <input
            id="profileImage"
            name="profileImage"
            type="file"
            class="form-control delivery-input"
            accept="image/*"
            aria-label="Foto de usuario"
          />
        </div>

        <div class="col-12 col-md-6">
          <input
            id="name"
            name="name"
            type="text"
            class="form-control delivery-input"
            value="{{formData.name}}"
            placeholder="Nombre"
            aria-label="Nombre"
            required
          />
        </div>

        <div class="col-12 col-md-6">
          <input
            id="lastName"
            name="lastName"
            type="text"
            class="form-control delivery-input"
            value="{{formData.lastName}}"
            placeholder="Apellido"
            aria-label="Apellido"
            required
          />
        </div>

        <div class="col-12">
          <input
            id="phone"
            name="phone"
            type="tel"
            class="form-control delivery-input"
            value="{{formData.phone}}"
            placeholder="Telefono"
            aria-label="Telefono"
            inputmode="numeric"
            pattern="[0-9]{7,15}"
            maxlength="15"
            oninput="this.value = this.value.replace(/[^0-9]/g, '')"
            required
          />
        </div>
      </div>

      <div class="d-flex gap-2 mt-4">
        <a href="/delivery/dashboard" class="btn btn-outline-secondary delivery-back w-50">
          <i class="bi bi-arrow-left me-1"></i>Volver
        </a>
        <button type="submit" class="btn delivery-submit w-50">
          <i class="bi bi-floppy me-1"></i>Guardar
        </button>
      </div>
    </form>
  </div>
</section>
