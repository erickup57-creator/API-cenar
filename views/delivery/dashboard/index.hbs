{{#section "styles"}}
<style>
  body {
    background: #032f3a;
  }

  main.container {
    max-width: 100%;
    margin-top: 0 !important;
    padding: 0;
  }

  .delivery-shell {
    min-height: calc(100vh - 56px);
    display: grid;
    place-items: start center;
    padding: 42px 16px;
  }

  .delivery-panel {
    width: 100%;
    max-width: 920px;
    background: #ececec;
    border-radius: 10px;
    padding: 22px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.24);
  }

  .delivery-title {
    margin: 0;
    color: #1f1f1f;
    font-size: 1.85rem;
    font-weight: 700;
    line-height: 1.1;
  }

  .delivery-subtitle {
    color: #666;
    font-size: 0.92rem;
    font-weight: 600;
  }

  .order-card {
    display: block;
    background: #f8f9fa;
    border: 1px solid #b9c6ce;
    border-radius: 6px;
    padding: 14px;
    color: inherit;
    text-decoration: none;
    transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
  }

  .order-card:hover {
    border-color: #19a8bd;
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.12);
    color: inherit;
    transform: translateY(-1px);
  }

  .commerce-logo,
  .commerce-placeholder {
    width: 48px;
    height: 48px;
    border-radius: 6px;
    object-fit: cover;
  }

  .commerce-placeholder {
    background: rgba(28, 166, 189, 0.16);
    color: #168ca0;
  }

  .order-meta {
    color: #666;
    font-size: 0.82rem;
    font-weight: 600;
  }

  .delivery-empty {
    background: #f8f9fa;
    border: 1px solid #b9c6ce;
    color: #4f4f4f;
    border-radius: 6px;
  }

  @media (max-width: 575.98px) {
    .delivery-shell {
      padding: 24px 12px;
    }

    .delivery-panel {
      padding: 18px;
    }
  }
</style>
{{/section}}

<section class="delivery-shell">
  <div class="delivery-panel">
    <div class="mb-4">
      <h1 class="delivery-title">Home del delivery</h1>
      <p class="delivery-subtitle mb-0 mt-2">Pedidos asignados a tu cuenta.</p>
    </div>

    {{#if loadError}}
      <div class="alert alert-danger py-2 mb-3" role="alert">
        No se pudieron cargar los pedidos asignados.
      </div>
    {{/if}}

    {{#if hasOrders}}
      <div class="d-flex flex-column gap-2">
        {{#each ordersList}}
          <a href="/delivery/orders/{{id}}" class="order-card">
            <div class="d-flex flex-column flex-sm-row gap-3 align-items-sm-start">
              {{#if commerceLogoUrl}}
                <img src="{{commerceLogoUrl}}" alt="Logo {{commerceName}}" class="commerce-logo flex-shrink-0" />
              {{else}}
                <div class="commerce-placeholder d-flex align-items-center justify-content-center flex-shrink-0">
                  <i class="bi bi-shop"></i>
                </div>
              {{/if}}

              <div class="flex-grow-1" style="min-width: 0;">
                <div class="d-flex flex-column flex-sm-row justify-content-between gap-2">
                  <h2 class="h6 fw-semibold text-dark mb-0 text-break">{{commerceName}}</h2>
                  <span class="badge {{statusBadgeClass}} align-self-start">{{statusLabel}}</span>
                </div>

                <div class="order-meta mt-2">
                  {{productsCount}} productos | {{totalLabel}}
                </div>
                <div class="text-muted small">{{createdAtLabel}}</div>
              </div>
            </div>
          </a>
        {{/each}}
      </div>
    {{else}}
      <div class="delivery-empty p-3" role="alert">
        <i class="bi bi-info-circle me-1"></i>No hay pedidos asignados para mostrar.
      </div>
    {{/if}}
  </div>
</section>
